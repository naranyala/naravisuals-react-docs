{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["bun", "jest"],
    "baseUrl": ".",
    "paths": {
      "@/generated/*": ["./apps/web/src/generated/*"],
      "@/generated": ["./apps/web/src/generated"],
      "@/shared/*": ["./apps/web/src/shared/*"],
      "@/services/*": ["./apps/web/src/services/*"],
      "@/*": ["./apps/web/src/*"]
    }
  },
  "include": ["tests/**/*", "apps/web/src/**/*", "packages/compiler-ts/**/*"],
  "exclude": ["node_modules", "dist"]
}
