{
  "name": "rspack-react-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "docts": "./scripts/cli.mts"
  },
  "scripts": {
    "dev": "bun run scripts/cli.mts dev",
    "build": "bun run scripts/cli.mts build",
    "start": "bun run scripts/cli.mts start",
    "preview": "bun run scripts/cli.mts preview",
    "build:docs": "bun run scripts/cli.mts docs",
    "test": "bun run scripts/cli.mts test",
    "test:watch": "bun run scripts/cli.mts test --watch",
    "test:coverage": "bun run scripts/cli.mts test --coverage",
    "type-check": "bunx tsc --noEmit",
    "rspack": "rspack",
    "lint": "bun run scripts/cli.mts lint",
    "lint:fix": "bun run scripts/cli.mts lint:fix",
    "verify-ci": "bun run scripts/verify-ci.mts",
    "clean": "bun run scripts/cli.mts clean",
    "info": "bun run scripts/cli.mts info",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "validate": "bun run scripts/validate-all.mts",
    "validate:strict": "bun run scripts/validate-all.mts --strict",
    "validate:stats": "bun run scripts/validate-all.mts --stats",
    "validate:llm": "bun run scripts/validate-all.mts --llm"
  },
  "dependencies": {
    "@leeoniya/ufuzzy": "^1.0.19",
    "@m31coding/fuzzy-search": "^2.0.0",
    "@preact/signals-react": "^3.10.1",
    "@sinclair/typebox": "^0.34.49",
    "better-result": "^2.9.2",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.3",
    "dompurify": "^3.4.2",
    "fast-glob": "^3.3.3",
    "fuse.js": "^7.3.0",
    "fuzzysort": "^3.1.0",
    "goober": "^2.1.18",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "is-number": "^7.0.0",
    "marked-footnote": "^1.4.0",
    "mathjax-full": "^3.2.2",
    "mermaid": "^11.15.0",
    "mitt": "^3.0.1",
    "nuqs": "^2.8.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "serve": "^14.2.6",
    "ts-pattern": "^5.9.0",
    "valtio": "^2.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@rspack/plugin-react-refresh": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.13",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.4",
    "html-rspack-plugin": "^6.1.8",
    "jsdom": "^29.1.1",
    "marked": "^18.0.3",
    "react-refresh": "^0.18.0",
    "shiki": "^4.0.2",
    "style-loader": "^4.0.0",
    "typescript": "^6.0.3"
  }
}
